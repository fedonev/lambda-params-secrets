{
  "name": "lambda-params-secrets",
  "version": "1.0.3",
  "description": "A Node.js client for the AWS Lambda Parameters and Secrets Extension",
  "repository": {
    "url": "https://github.com/fedonev/lambda-params-secrets.git",
    "type": "git"
  },
  "homepage": "https://fedonev.github.io/lambda-params-secrets/",
  "keywords": [
    "AWS",
    "Lambda",
    "Systems Manager Parameter Store",
    "Secrets Manager",
    "Node.js"
  ],
  "author": "fedonev",
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "build": "tsc --noEmit",
    "watch": "tsc --noEmit -w",
    "pretest": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint .",
    "build-docs": "npx typedoc",
    "---- CDK Test App (Uses the default AWS profile. Alternatively, run: `npm run cdk-synth -- --profile my-profile`) ----": "",
    "cdk-synth": "npx cdk synth '*' --output ./cdk/cdk.out",
    "precdk-deploy": "npm test",
    "prepublish": "./scripts/prepare-dist.sh",
    "cdk-deploy": "npx cdk deploy '*' --output ./cdk/cdk.out --outputs-file ./cdk/cdk.outputs.json",
    "cdk-destroy": "npx cdk destroy '*' --output ./cdk/cdk.out"
  },
  "devDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1078.0",
    "@aws-sdk/client-ssm": "^3.1078.0",
    "@types/aws-lambda": "^8.10.162",
    "@types/jest": "^30.0.0",
    "@types/node": "~24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "aws-cdk": "^2.1129.0",
    "aws-cdk-lib": "^2.260.0",
    "constructs": "^10.6.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "prettier": "^3.9.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3"
  }
}
